# daves-vibe-kanban 本地开发配置示例
# 复制为 .env 后按需修改：cp .env.example .env

# 复用官方 vibe-kanban 的数据目录（保留原有 issue、workspace、对话记录）
# macOS: "/Users/xxx/Library/Application Support/ai.bloop.vibe-kanban"
# Linux: "/home/xxx/.local/share/ai.bloop.vibe-kanban"
VK_ASSET_DIR=""

# 远程 API（用于 OAuth 登录等）
VK_SHARED_API_BASE=https://api.vibekanban.com
